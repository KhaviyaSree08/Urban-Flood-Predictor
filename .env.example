# Configuration File for AI Urban Flood Prediction System

# API Configuration
API_URL=http://localhost:5000
FRONTEND_PORT=3000
BACKEND_PORT=5000

# Risk Thresholds
RISK_LOW_THRESHOLD=0.3
RISK_MEDIUM_THRESHOLD=0.5
RISK_HIGH_THRESHOLD=0.7

# Alert Configuration
ALERT_HIGH_RISK_THRESHOLD=0.7
ALERT_CRITICAL_THRESHOLD=0.85
ALERT_REFRESH_INTERVAL=10000

# Map Configuration
DEFAULT_MAP_CENTER_LAT=40.7128
DEFAULT_MAP_CENTER_LNG=-74.0060
DEFAULT_MAP_ZOOM=11

# Prediction Configuration
DEFAULT_FORECAST_DAYS=7
MAX_FORECAST_DAYS=14
MIN_FORECAST_DAYS=1

# Model Configuration
MODEL_PATH=models/flood_model.pkl
TRAINING_DATA_PATH=data/flood_training_data.csv
RANDOM_SEED=42
N_ESTIMATORS=100
MAX_DEPTH=10

# Feature Weights (for fallback calculation)
RAINFALL_WEIGHT=0.4
HUMIDITY_WEIGHT=0.3
ELEVATION_WEIGHT=0.01
DRAINAGE_WEIGHT=0.2
TEMPERATURE_WEIGHT=0.1

# Database Configuration (Optional)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flood_prediction
DB_USER=root
DB_PASSWORD=

# Theme Colors
PRIMARY_COLOR=#2196f3
SECONDARY_COLOR=#1976d2
ACCENT_COLOR=#64b5f6
BACKGROUND_COLOR=#0a1929
CARD_BACKGROUND=rgba(26, 35, 50, 0.9)

# Risk Colors
RISK_LOW_COLOR=#4caf50
RISK_MEDIUM_COLOR=#ffeb3b
RISK_HIGH_COLOR=#ff9800
RISK_CRITICAL_COLOR=#f44336
